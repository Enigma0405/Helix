# ============================================================
# Project Helix — .gitignore
# ============================================================

# ------------------------------------------------------------
# Secrets & Environment
# ------------------------------------------------------------
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
*.crt
secrets/

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage/
coverage.xml
htmlcov/
*.lcov
nosetests.xml
test-results/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Linting
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ------------------------------------------------------------
# Node / JavaScript / React
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# Package lock (keep one, ignore the others)
# Uncomment your preferred lockfile strategy:
# package-lock.json
# yarn.lock

# Storybook
storybook-static/

# ------------------------------------------------------------
# Docker & Container Data
# ------------------------------------------------------------
pgdata/
minio_data/
.docker/

# ------------------------------------------------------------
# Editor & OS
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# JetBrains IDEs
.idea/
*.iml
*.iws

# VS Code (keep settings, ignore personal overrides)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*#
.#*

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
*.log.*
log/

# ------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig

# ------------------------------------------------------------
# Generated / Artifacts
# ------------------------------------------------------------
evaluation/results/
evaluation/benchmarks/results/
sample_data/generated/
scripts/__pycache__/

# Generated PDFs and exports (exclude demo fixtures)
exports/
*.pdf
!sample_data/**/*.pdf
!evaluation/golden_cases/**/*.pdf

# ------------------------------------------------------------
# SQLite Databases
# ------------------------------------------------------------
*.db
*.db-shm
*.db-wal
