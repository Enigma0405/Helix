# ============================================================
# Project Helix — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ------------------------------------------------------------
POSTGRES_USER=helix
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=helixdb

# Full connection URL (auto-constructed in docker-compose.yml
# for container networking; override here for local dev)
DATABASE_URL=postgresql+asyncpg://helix:change_me_in_production@localhost:5432/helixdb

# ------------------------------------------------------------
# MinIO Object Storage (S3-compatible)
# ------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# Bucket names (created automatically by scripts/create_buckets.py)
MINIO_EVIDENCE_BUCKET=helix-evidence
MINIO_DOCUMENTS_BUCKET=helix-documents
MINIO_EXPORTS_BUCKET=helix-exports

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_secure_random_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# AI Runtime — Inference Provider
# ------------------------------------------------------------
# Options: mock | fireworks | openai | local
# - mock: Returns deterministic fake responses (unit tests / CI / dev without API key)
# - fireworks: Fireworks AI API → routes to AMD Instinct MI300X via Gemma 4 31B IT
# - openai: OpenAI API (fallback)
# - local: Local Ollama/llama.cpp instance
INFERENCE_PROVIDER=mock

# Fireworks AI (required when INFERENCE_PROVIDER=fireworks)
# Get your API key at: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=
# Gemma 4 31B IT is the preferred demo model (April 2026, AMD Instinct MI300X optimized)
FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-31b-it
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# OpenAI (required when INFERENCE_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Local inference (required when INFERENCE_PROVIDER=local)
LOCAL_INFERENCE_URL=http://localhost:11434/api

# ------------------------------------------------------------
# Embedding Model
# ------------------------------------------------------------
# Options: local | fireworks
# - local: sentence-transformers/all-MiniLM-L6-v2 (runs in backend container)
# - fireworks: nomic-ai/nomic-embed-text-v1.5 via Fireworks API
EMBEDDING_MODEL=local
EMBEDDING_DIMENSION=384

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
# Options: development | production
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:80"]

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_EVIDENCE_FILE_SIZE_MB=50

# Chunking strategy for document ingestion
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ------------------------------------------------------------
# Frontend (React)
# ------------------------------------------------------------
REACT_APP_API_URL=http://localhost/api
REACT_APP_ENVIRONMENT=development
